<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>Mol.Format</PackageId>
    <Version>0.1.0</Version>
    <Authors>mol-format</Authors>
    <Description>.NET serializer and deserializer for Markdown Object Language (MOL).</Description>
    <PackageTags>mol markdown serialization parser config</PackageTags>
    <RepositoryUrl>https://github.com/mol-format/mol-net</RepositoryUrl>
    <PackageLicenseFile>LICENSE.md</PackageLicenseFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\LICENSE.md" Pack="true" PackagePath="\" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
